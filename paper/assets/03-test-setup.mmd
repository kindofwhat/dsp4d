---
title: Test Setup – Evaluation Pipeline
---
flowchart TD
    subgraph INPUT ["Test Case"]
        direction LR
        Q["Clinical Document"]
        SP["System Prompt"]
        GA["Golden Answer"]
    end

    subgraph EXECUTION ["Test Run Execution"]
        direction TB
        LLM1["LLM under Test<br/>(e.g. Gemma, LLaMA,<br/>Gemini, GPT)"]
        RESP["Generated Response"]
        LLM1 --> RESP
    end

    subgraph EVAL ["Evaluation"]
        direction LR
        STAT["Statistical Metrics<br/>BLEU, ROUGE, Token F1,<br/>Levenshtein, Semantic Sim.,<br/>JSON Structural Sim."]
        JUDGE_LLM["Judge LLM<br/>(GPT-4.1-mini)"]
        GEN["Generative Metrics<br/>Medical Field Comparison,<br/>Medical Semantic Field<br/>Comparison (DAG)"]
        JUDGE_LLM --> GEN
    end

    subgraph OUTPUT ["Results"]
        direction TB
        SCORES["Metric Scores<br/>per Test Case"]
        AGG["Aggregated<br/>Comparison"]
        SCORES --> AGG
    end

    Q --> LLM1
    SP --> LLM1
    RESP --> STAT
    RESP --> JUDGE_LLM
    GA --> STAT
    GA --> JUDGE_LLM
    STAT --> SCORES
    GEN --> SCORES

    style INPUT fill:#fff3e0,stroke:#333
    style EXECUTION fill:#e3f2fd,stroke:#333
    style EVAL fill:#f0f4ff,stroke:#7799cc,stroke-dasharray: 5 5
    style OUTPUT fill:#e8f5e9,stroke:#333
    style LLM1 fill:#bbdefb,stroke:#333
    style JUDGE_LLM fill:#c8e6c9,stroke:#333
    style STAT fill:#f5f5f5,stroke:#333
    style GEN fill:#f5f5f5,stroke:#333
