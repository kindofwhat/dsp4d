---
title: Test Setup – Evaluation Pipeline
---
flowchart TD
    subgraph LOCAL ["llm-validator"]
        direction TB
        subgraph INPUT ["Test Cases"]
            direction LR
            Q["Clinical Document"]
            SP["System Prompt"]
        end

        subgraph EVAL ["Evaluation Pipeline"]
            direction LR
            STAT["Statistical Metrics<br/>BLEU, ROUGE, Token F1,<br/>Levenshtein, Semantic Sim.,<br/>JSON Structural Sim."]
            GA["Silver Answer"]
            RESP["LLM Response"]
        end

        subgraph OUTPUT ["Result Aggregation"]
            direction TB
            SCORES["Metric Scores<br/>per Test Case"]
            AGG["Aggregated<br/>Comparison"]
            GEN["Generative Metrics<br/>Medical Field Comparison,<br/>Medical Semantic Field<br/>Comparison (DAG)"]
            SCORES --> AGG
        end
    end

    subgraph CLOUD ["OpenAI Cloud (API)"]
        direction TB
        JUDGE_LLM["Judge LLM<br/>(GPT-4.1-mini)"]
        JUDGE_LLM --> GEN
    end

    subgraph EXECUTION ["Ollama Model Serving"]
        direction TB
        LLM1["LLM under Test<br/>(e.g. Gemma, LLaMA,<br/>Gemini, GPT)"]
        LLM1 --> RESP
    end

    SGF["Silver Generation<br/>Framework"]

    SGF -.-> Q
    SGF -.->SP
    SGF -.-> GA

    Q --> LLM1
    SP --> LLM1
    RESP --> STAT
    RESP --> JUDGE_LLM
    GA --> STAT
    GA --> JUDGE_LLM
    STAT --> SCORES
    GEN --> SCORES

